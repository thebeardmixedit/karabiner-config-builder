#!/usr/bin/env bash

set -euo pipefail

project_dir="$HOME/Code/personal/karabiner-config-builder"
dotfiles_config="$HOME/.dotfiles/karabiner/karabiner.json"
live_config="$HOME/.config/karabiner/karabiner.json"

cd "$project_dir"

npm run check
npm run build

mkdir -p "$(dirname "$dotfiles_config")"
mkdir -p "$(dirname "$live_config")"

cp "$project_dir/karabiner.json" "$dotfiles_config"
ln -sf "$dotfiles_config" "$live_config"

echo "Deployed Karabiner config:"
echo "  generated: $project_dir/karabiner.json"
echo "  dotfiles:  $dotfiles_config"
echo "  live:      $live_config -> $dotfiles_config"
