#!/usr/bin/env bash

set -euo pipefail

config_file="${HOME}/.config/karabiner/karabiner.json"
backup_dir="${HOME}/.config/karabiner/kcb_backups"
timestamp="$(date +%Y%m%d-%H%M%S)"
backup_file="${backup_dir}/karabiner.${timestamp}.json"

if [[ ! -f "${config_file}" ]]; then
    echo "Karabiner config not found: ${config_file}" >&2
    exit 1
fi

mkdir -p "${backup_dir}"

cat "${config_file}" >"${backup_file}"

echo "Backed up Karabiner config:"
echo "${backup_file}"
