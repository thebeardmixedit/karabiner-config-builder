{
  "name": "karabiner-config-builder",
  "version": "0.1.0",
  "private": true,
  "description": "A TypeScript builder for generating karabiner.json.",
  "type": "module",
  "scripts": {
    "build": "tsx src/index.ts",
    "watch": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "check": "tsc --noEmit",
    "deploy": "./bin/deploy"
  },
  "keywords": [
    "karabiner",
    "karabiner-elements",
    "typescript",
    "keyboard",
    "keybindings"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thebeardmixedit/karabiner-config-builder.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "nodemon": "^3.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
