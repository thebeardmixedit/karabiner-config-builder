{
    "name": "karabiner-config-builder",
    "version": "0.1.0",
    "private": false,
    "description": "A TypeScript builder for generating karabiner.json.",
    "type": "module",
    "scripts": {
        "check": "tsc --noEmit",
        "build": "tsx src/cli/build.ts",
        "build:test:bind": "tsx src/cli/build.ts --config tests/bind.ts",
        "build:test:layer": "tsx src/cli/build.ts --config tests/layer.ts",
        "build:test:conditions": "tsx src/cli/build.ts --config tests/conditions.ts",
        "deploy": "tsx src/cli/deploy.ts",
        "deploy:test:bind": "tsx src/cli/deploy.ts --config tests/bind.ts",
        "deploy:test:layer": "tsx src/cli/deploy.ts --config tests/layer.ts",
        "deploy:test:conditions": "tsx src/cli/deploy.ts --config tests/conditions.ts",
        "backup": "bin/backup",
        "restore": "bin/restore",
        "restore:search": "bin/restore --search"
    },
    "keywords": [
        "karabiner",
        "karabiner-elements",
        "typescript",
        "keyboard",
        "keybindings"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thebeardmixedit/karabiner-config-builder.git"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^24.0.0",
        "nodemon": "^3.1.0",
        "tsx": "^4.20.0",
        "typescript": "^5.8.0"
    }
}
